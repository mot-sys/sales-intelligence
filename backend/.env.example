# Application Settings
APP_NAME=Signal Intelligence
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/signal_intel

# Redis
REDIS_URL=redis://localhost:6379/0

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-this-in-production-use-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (add your frontend URL)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# External APIs - Clay
CLAY_API_KEY=your_clay_api_key_here
CLAY_BASE_URL=https://api.clay.com/v1

# External APIs - Salesforce
SALESFORCE_CLIENT_ID=your_sf_client_id
SALESFORCE_CLIENT_SECRET=your_sf_client_secret
SALESFORCE_USERNAME=your_sf_username
SALESFORCE_PASSWORD=your_sf_password
SALESFORCE_SECURITY_TOKEN=your_sf_security_token
SALESFORCE_DOMAIN=login

# External APIs - Snitcher
SNITCHER_API_KEY=your_snitcher_api_key
SNITCHER_BASE_URL=https://snitcher.com/api/v2

# External APIs - Outreach.io
OUTREACH_API_KEY=your_outreach_api_key
OUTREACH_BASE_URL=https://api.outreach.io/api/v2

# OpenAI (for AI recommendations)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4-turbo-preview

# Celery (Task Queue)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Monitoring (optional)
SENTRY_DSN=

# ML Model
ML_MODEL_PATH=./models
ML_MODEL_VERSION=v1
